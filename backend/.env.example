# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=saas_erp
DB_USER=postgres
DB_PASSWORD=your_strong_password_here
DB_POOL_MAX=20

# ── JSON Web Token ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=8h

# Used to sign the HTTP-only cookie holding the JWT
COOKIE_SECRET=REPLACE_WITH_ANOTHER_STRONG_SECRET
